{
  "name": "@cplieger/ui-primitives",
  "version": "1.0.0",
  "type": "module",
  "description": "Headless browser UI primitives (toast, tooltip, popover, popup, dialog, modal, confirm, prompt, disclosure, focus-trap, roving-focus, theme, view-transition, announce, skeleton) with behavior + accessibility + a documented CSS class/custom-property contract. Consuming apps supply only skin CSS. Built on @cplieger/reactive.",
  "license": "GPL-3.0-or-later",
  "exports": {
    ".": "./src/index.ts",
    "./toast": "./src/toast/index.ts",
    "./tooltip": "./src/tooltip.ts",
    "./popover": "./src/popover.ts",
    "./popup": "./src/popup.ts",
    "./dialog": "./src/dialog.ts",
    "./modal": "./src/modal.ts",
    "./confirm": "./src/confirm.ts",
    "./prompt": "./src/prompt.ts",
    "./disclosure": "./src/disclosure.ts",
    "./focus-trap": "./src/focus-trap.ts",
    "./roving-focus": "./src/roving-focus.ts",
    "./skeleton": "./src/skeleton.ts",
    "./theme": "./src/theme.ts",
    "./view-transition": "./src/view-transition.ts",
    "./announce": "./src/announce.ts",
    "./css": "./css/ui-primitives.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint:stylelint": "stylelint \"css/**/*.css\"",
    "lint:fix": "eslint . --fix && prettier --write .",
    "lint:knip": "knip"
  },
  "dependencies": {
    "@cplieger/reactive": "^1.2.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "25.9.5",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "fast-check": "4.9.0",
    "happy-dom": "20.10.6",
    "html-validate": "11.5.6",
    "knip": "6.26.0",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cplieger/ui-primitives.git"
  },
  "files": [
    "src/",
    "css/",
    "LICENSE",
    "README.md",
    "!src/**/*.test.ts",
    "!src/**/fc-strict-setup.ts"
  ]
}
